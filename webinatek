      gap:20px;
      position:relative;
      z-index:1;
    }
    .stat-item{
      text-align:center;
      opacity:0;
      transform:translateY(16px);
      transition:opacity .6s ease, transform .6s ease;
    }
    .stats-strip.is-visible .stat-item{ opacity:1; transform:translateY(0); }
