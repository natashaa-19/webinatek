<script>
  // Storage adapter 3 lapis:
  // 1) window.storage  -> aktif saat dibuka di preview Claude
  // 2) localStorage     -> aktif saat dibuka sebagai website (http/https)
  // 3) memori halaman   -> cadangan terakhir, selalu berhasil (mis. saat file
  //                        dibuka langsung dari komputer / protokol file://
  //                        yang sering memblokir localStorage)
  const LS_PREFIX = 'inatek_';
  const memoryStore = {};

  const storageAdapter = {
    async set(key, value) {
      try {
        if (typeof window.storage !== 'undefined' && window.storage) {
          const res = await window.storage.set(key, value, true);
          if (res) return res;
        }
      } catch (err) { console.warn('window.storage.set gagal:', err); }

      try {
        localStorage.setItem(LS_PREFIX + key, value);
        memoryStore[key] = value;
        return { key, value, shared: true };
      } catch (err) {
        console.warn('localStorage.setItem gagal, simpan ke memori halaman:', err);
      }

      memoryStore[key] = value;
      return { key, value, shared: true };
    },
    async get(key) {
      try {
        if (typeof window.storage !== 'undefined' && window.storage) {
          const res = await window.storage.get(key, true);
          if (res) return res;
        }
      } catch (err) { /* lanjut ke fallback */ }

      try {
        const value = localStorage.getItem(LS_PREFIX + key);
        if (value !== null) return { key, value, shared: true };
      } catch (err) { /* lanjut ke fallback */ }

      if (Object.prototype.hasOwnProperty.call(memoryStore, key)) {
        return { key, value: memoryStore[key], shared: true };
      }
      throw new Error('Key not found: ' + key);
    },
    async list(prefix) {
      const keySet = new Set();

      try {
        if (typeof window.storage !== 'undefined' && window.storage) {
          const res = await window.storage.list(prefix, true);
          if (res && res.keys) res.keys.forEach(k => keySet.add(k));
        }
      } catch (err) { /* lanjut ke fallback */ }

      try {
        for (let i = 0; i < localStorage.length; i++) {
          const rawKey = localStorage.key(i);
          if (rawKey && rawKey.startsWith(LS_PREFIX + prefix)) {
            keySet.add(rawKey.slice(LS_PREFIX.length));
          }
        }
      } catch (err) { /* lanjut ke fallback */ }

      Object.keys(memoryStore).forEach(k => {
        if (k.startsWith(prefix)) keySet.add(k);
      });

      return { keys: Array.from(keySet), prefix, shared: true };
    }
  };

  const menuToggle = document.getElementById('menuToggle');
  const mainMenu = document.getElementById('mainMenu');

  function setMenuState(open) {
    mainMenu.classList.toggle('is-open', open);
    menuToggle.classList.toggle('is-active', open);
    menuToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    menuToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  }

  menuToggle.addEventListener('click', () => {
    setMenuState(!mainMenu.classList.contains('is-open'));
  });

  document.querySelectorAll('#mainMenu a').forEach(link => {
    link.addEventListener('click', () => setMenuState(false));
  });

  document.addEventListener('click', (e) => {
    if (window.innerWidth <= 560 && !e.target.closest('header')) {
      setMenuState(false);
    }
  });

  const slides = document.querySelectorAll('.hero-slide');
  const dotsWrap = document.getElementById('heroDots');
  let current = 0;

  slides.forEach((_, i) => {
    const dot = document.createElement('span');
    if (i === 0) dot.classList.add('is-active');
    dot.setAttribute('role', 'button');
    dot.setAttribute('tabindex', '0');
    dot.setAttribute('aria-label', `Slide ${i + 1}`);
    dot.addEventListener('click', () => setSlide(i));
    dot.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') setSlide(i);
    });
    dotsWrap.appendChild(dot);
  });

  const dots = dotsWrap.querySelectorAll('span');
  function setSlide(i){
    slides[current].classList.remove('is-active');
    dots[current].classList.remove('is-active');
    current = i;
    slides[current].classList.add('is-active');
    dots[current].classList.add('is-active');
  }

  setInterval(() => setSlide((current + 1) % slides.length), 5000);

  const portfolioSlider = document.getElementById('portfolioSlider');
  portfolioSlider.addEventListener('click', () => {
    portfolioSlider.classList.toggle('is-paused');
  });

  const openContactForm = document.getElementById('openContactForm');
  const contactModal = document.getElementById('contactModal');
  const closeContactForm = document.getElementById('closeContactForm');
  const closeContactBtn = document.getElementById('closeContactBtn');
  const cancelContactBtn = document.getElementById('cancelContactBtn');
  const contactForm = document.getElementById('contactForm');
  const formNote = document.getElementById('formNote');

  function openContactModal(){
    contactModal.classList.add('is-open');
    contactModal.setAttribute('aria-hidden', 'false');
  }
  function closeContactModal(){
    contactModal.classList.remove('is-open');
    contactModal.setAttribute('aria-hidden', 'true');
  }

  openContactForm.addEventListener('click', openContactModal);
  closeContactForm.addEventListener('click', closeContactModal);
  closeContactBtn.addEventListener('click', closeContactModal);
  cancelContactBtn.addEventListener('click', closeContactModal);

  document.addEventListener('keydown', (e) => {
    if(e.key === 'Escape'){
      closeContactModal();
      closePortfolioModal();
      setMenuState(false);
    }
  });

  document.addEventListener('keydown', (e) => {
    if(e.key === 'Escape'){
      if (typeof closeAdminLoginModal === 'function') closeAdminLoginModal();
      if (typeof closeAdminDashboardModal === 'function') closeAdminDashboardModal();
    }
  });

  contactForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fullName = document.getElementById('fullName').value.trim();
    const email = document.getElementById('email').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const message = document.getElementById('message').value.trim();

    if (!fullName || !email || !phone || !message) {
      formNote.textContent = 'Semua field harus diisi.';
      formNote.style.color = 'var(--danger)';
      return;
    }

    const submitBtn = contactForm.querySelector('button[type="submit"]');
    submitBtn.disabled = true;

    const report = {
      fullName,
      email,
      phone,
      message,
      submittedAt: new Date().toISOString()
    };
    const key = `reports:${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;

    try {
      const result = await storageAdapter.set(key, JSON.stringify(report));
      if (!result) throw new Error('Storage returned no result');
      formNote.textContent = 'Pesan berhasil dikirim dan tersimpan di dashboard admin.';
      formNote.style.color = '#5B98D2';
      setTimeout(() => {
        formNote.textContent = '';
        closeContactModal();
        contactForm.reset();
        submitBtn.disabled = false;
      }, 1400);
    } catch (err) {
      console.error('Gagal menyimpan laporan:', err);
      formNote.textContent = 'Gagal mengirim pesan, silakan coba lagi.';
      formNote.style.color = 'var(--danger)';
      submitBtn.disabled = false;
    }
  });

  const portfolioModal = document.getElementById('portfolioModal');
  const closePortfolioForm = document.getElementById('closePortfolioForm');
  const closePortfolioBtn = document.getElementById('closePortfolioBtn');
  const portfolioImage = document.getElementById('portfolioImage');
  const portfolioName = document.getElementById('portfolioName');
  const portfolioType = document.getElementById('portfolioType');
  const portfolioDesc = document.getElementById('portfolioDesc');

  function openPortfolioModal(card){
    portfolioImage.src = card.querySelector('img').src;
    portfolioName.textContent = card.dataset.title;
    portfolioType.textContent = `Tipe: ${card.dataset.type}`;
    portfolioDesc.textContent = card.dataset.desc;
    portfolioModal.classList.add('is-open');
    portfolioModal.setAttribute('aria-hidden', 'false');
  }
  function closePortfolioModal(){
    portfolioModal.classList.remove('is-open');
    portfolioModal.setAttribute('aria-hidden', 'true');
  }

  document.querySelectorAll('.p-tile').forEach(card => {
    card.addEventListener('click', () => {
      if(card.dataset.title) openPortfolioModal(card);
    });
  });

  closePortfolioForm.addEventListener('click', closePortfolioModal);
  closePortfolioBtn.addEventListener('click', closePortfolioModal);

  const ADMIN_USERNAME = 'admin';
  const ADMIN_PASSWORD = 'admin123';
  let isAdminLoggedIn = false;

  const adminFabBtn = document.getElementById('adminFabBtn');
  const adminLoginModal = document.getElementById('adminLoginModal');
  const closeAdminLogin = document.getElementById('closeAdminLogin');
  const closeAdminLoginBtn = document.getElementById('closeAdminLoginBtn');
  const cancelAdminLoginBtn = document.getElementById('cancelAdminLoginBtn');
  const adminLoginForm = document.getElementById('adminLoginForm');
  const adminLoginError = document.getElementById('adminLoginError');

  const adminDashboardModal = document.getElementById('adminDashboardModal');
  const closeAdminDashboard = document.getElementById('closeAdminDashboard');
  const closeAdminDashboardBtn = document.getElementById('closeAdminDashboardBtn');
  const adminLogoutBtn = document.getElementById('adminLogoutBtn');
  const adminReportList = document.getElementById('adminReportList');
  const adminStatTotal = document.getElementById('adminStatTotal');

  function openAdminLoginModal(){
    adminLoginError.textContent = '';
    adminLoginModal.classList.add('is-open');
    adminLoginModal.setAttribute('aria-hidden', 'false');
  }
  function closeAdminLoginModal(){
    adminLoginModal.classList.remove('is-open');
    adminLoginModal.setAttribute('aria-hidden', 'true');
    adminLoginForm.reset();
    adminLoginError.textContent = '';
  }
  function openAdminDashboardModal(){
    adminDashboardModal.classList.add('is-open');
    adminDashboardModal.setAttribute('aria-hidden', 'false');
    loadAdminReports();
  }
  function closeAdminDashboardModal(){
    adminDashboardModal.classList.remove('is-open');
    adminDashboardModal.setAttribute('aria-hidden', 'true');
  }

  adminFabBtn.addEventListener('click', () => {
    if (isAdminLoggedIn) {
      openAdminDashboardModal();
    } else {
      openAdminLoginModal();
    }
  });

  closeAdminLogin.addEventListener('click', closeAdminLoginModal);
  closeAdminLoginBtn.addEventListener('click', closeAdminLoginModal);
  cancelAdminLoginBtn.addEventListener('click', closeAdminLoginModal);

  adminLoginForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const username = document.getElementById('adminUsername').value.trim();
    const password = document.getElementById('adminPassword').value;

    if (username === ADMIN_USERNAME && password === ADMIN_PASSWORD) {
      isAdminLoggedIn = true;
      closeAdminLoginModal();
      openAdminDashboardModal();
    } else {
      adminLoginError.textContent = 'Username atau password salah.';
    }
  });

  closeAdminDashboard.addEventListener('click', closeAdminDashboardModal);
  adminLogoutBtn.addEventListener('click', () => {
    isAdminLoggedIn = false;
    closeAdminDashboardModal();
  });

  function escapeHtml(str){
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatDate(iso){
    try {
      const d = new Date(iso);
      return d.toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' });
    } catch {
      return iso;
    }
  }

  async function loadAdminReports(){
    adminReportList.innerHTML = '<p class="admin-empty">Memuat laporan...</p>';
    try {
      const listResult = await storageAdapter.list('reports:');
      const keys = (listResult && listResult.keys) ? listResult.keys : [];

      if (keys.length === 0) {
        adminReportList.innerHTML = '<p class="admin-empty">Belum ada laporan masuk.</p>';
        adminStatTotal.textContent = '0';
        return;
      }

      const reports = [];
      for (const key of keys) {
        try {
          const item = await storageAdapter.get(key);
          if (item && item.value) {
            reports.push(JSON.parse(item.value));
          }
        } catch (err) {
          console.error('Gagal membaca laporan:', key, err);
        }
      }

      reports.sort((a, b) => new Date(b.submittedAt) - new Date(a.submittedAt));
      adminStatTotal.textContent = String(reports.length);

      if (reports.length === 0) {
        adminReportList.innerHTML = '<p class="admin-empty">Belum ada laporan masuk.</p>';
        return;
      }

      adminReportList.innerHTML = reports.map(r => `
        <div class="admin-report-card">
          <div class="arc-top">
            <span class="arc-name">${escapeHtml(r.fullName)}</span>
            <span class="arc-time">${escapeHtml(formatDate(r.submittedAt))}</span>
          </div>
          <div class="arc-meta">${escapeHtml(r.email)} &middot; ${escapeHtml(r.phone)}</div>
          <div class="arc-msg">${escapeHtml(r.message)}</div>
        </div>
      `).join('');
    } catch (err) {
      console.error('Gagal memuat laporan:', err);
      adminReportList.innerHTML = '<p class="admin-empty">Gagal memuat laporan. Silakan coba lagi.</p>';
    }
  }

  const heroSection = document.querySelector('.hero');
  const heroSlidesWrap = document.querySelector('.hero-slides');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (heroSection && heroSlidesWrap && !prefersReducedMotion) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const offset = window.scrollY;
          if (offset < heroSection.offsetHeight) {
            heroSlidesWrap.style.transform = `translateY(${offset * 0.22}px)`;
          }
          ticking = false;
        });
        ticking = true;
      }
    });
  }

  const revealTargets = document.querySelectorAll('.section');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if(entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { threshold: 0.18 });

  revealTargets.forEach(el => observer.observe(el));

  // Scroll progress bar
  const scrollProgress = document.getElementById('scrollProgress');
  function updateScrollProgress(){
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    if (scrollProgress) scrollProgress.style.width = pct + '%';
  }
  window.addEventListener('scroll', updateScrollProgress, { passive: true });
  updateScrollProgress();

  // Hero heading word-by-word reveal (keeps each .line on its own row)
  if (!prefersReducedMotion) {
    const heroH1 = document.querySelector('.hero-inner h1');
    if (heroH1) {
      const lines = heroH1.querySelectorAll('.line');
      let wordIndex = 0;
      lines.forEach(line => {
        const words = line.textContent.trim().split(/\s+/);
        line.innerHTML = words.map((w) => {
          const span = `<span class="word" style="animation-delay:${0.15 + wordIndex * 0.07}s">${w}</span>`;
          wordIndex++;
          return span;
        }).join(' ');
      });
    }
  }

  // Hero cursor spotlight
  if (heroSection && !prefersReducedMotion) {
    heroSection.addEventListener('mousemove', (e) => {
      const rect = heroSection.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      heroSection.style.setProperty('--spot-x', x + '%');
      heroSection.style.setProperty('--spot-y', y + '%');
    });
  }

  // Stats count-up
  const statsStrip = document.querySelector('.stats-strip');
  if (statsStrip) {
    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          statsStrip.classList.add('is-visible');
          statsStrip.querySelectorAll('.stat-num').forEach(el => {
            const target = parseInt(el.dataset.count, 10) || 0;
            const suffix = el.dataset.suffix || '';
            const duration = 1200;
            const start = performance.now();
            function tick(now){
              const progress = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              el.textContent = Math.round(eased * target) + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
          });
          statObserver.disconnect();
        }
      });
    }, { threshold: 0.4 });
    statObserver.observe(statsStrip);
  }

  // Back to top button
  const backToTop = document.getElementById('backToTop');
  if (backToTop) {
    window.addEventListener('scroll', () => {
      backToTop.classList.toggle('is-visible', window.scrollY > 500);
    }, { passive: true });
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Subtle 3D tilt on cards
  if (!prefersReducedMotion && window.matchMedia('(hover:hover)').matches) {
    document.querySelectorAll('.service-card, .value-card, .p-tile').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const px = (e.clientX - rect.left) / rect.width - 0.5;
        const py = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = `translateY(-6px) rotateX(${(-py * 8).toFixed(2)}deg) rotateY(${(px * 8).toFixed(2)}deg)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });
  }
</script>
</body>
</html>
