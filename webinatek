<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Inatek Corp — Sistem Digital untuk Setiap Industri</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=Lora:wght@400;500;600;700&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg:#F3F7FB;
      --silver:#E5EAF0;
      --navy:#6FA8DC;
      --navy-2:#5B98D2;
      --navy-soft:#8FC1E8;
      --ink:#2A3542;
      --muted:#6B7684;
      --white:#FFFFFF;
      --line:rgba(111,168,220,0.16);
      --danger:#b42318;
      --header-bg:rgba(255,255,255,0.88);
      --header-ink:#2A3542;
    }

    *{ box-sizing:border-box; margin:0; padding:0; }
    html{ scroll-behavior:smooth; scroll-padding-top:90px; }
    body{
      font-family:'Lora',serif;
      background:var(--bg);
      color:var(--ink);
      overflow-x:hidden;
      -webkit-font-smoothing:antialiased;
      line-height:1.6;
    }
    a{ text-decoration:none; color:inherit; }
    img{ display:block; max-width:100%; }
    button,input,textarea{ font:inherit; }
    section{ position:relative; }

    header{
      position:sticky;
      top:0;
      z-index:999;
      padding:18px 48px;
      background:var(--header-bg);
      backdrop-filter:blur(10px);
      -webkit-backdrop-filter:blur(10px);
      border-bottom:1px solid var(--line);
      box-shadow:0 2px 18px rgba(111,168,220,0.10);
      animation:navDrop .8s ease both;
    }
    .nav-inner{
      max-width:1240px;
      margin:0 auto;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
      position:relative;
    }
    .logo{
      display:flex;
      align-items:center;
      gap:10px;
      font-family:'Poppins',sans-serif;
      font-weight:700;
      font-size:20px;
      color:var(--header-ink);
      letter-spacing:-0.01em;
      white-space:nowrap;
    }
    .logo-mark{
      width:32px;
      height:32px;
      border-radius:8px;
      background:rgba(111,168,220,0.14);
      border:1px solid rgba(111,168,220,0.4);
      position:relative;
      flex-shrink:0;
    }
    .logo-mark::before{
      content:"";
      position:absolute;
      inset:8px;
      border-radius:2px;
      background:var(--navy);
      clip-path:polygon(0 100%,100% 100%,100% 30%,55% 30%,55% 0,25% 0,25% 60%,0 60%);
    }

    nav.menu{
      display:flex;
      align-items:center;
      gap:30px;
    }
    nav.menu a{
      font-family:'Poppins',sans-serif;
      font-size:15px;
      font-weight:600;
      color:var(--header-ink);
      position:relative;
      padding:4px 0;
      opacity:.85;
      transition:transform .25s ease, opacity .25s ease, color .25s ease;
    }
    nav.menu a:hover{
      color:var(--navy);
    }
    nav.menu a::after{
      content:"";
      position:absolute;
      left:0;
      bottom:-2px;
      width:0;
      height:2px;
      background:var(--navy);
      transition:width .25s ease;
    }
    nav.menu a:hover{
      transform:translateY(-1px);
      opacity:1;
    }
    nav.menu a:hover::after{ width:100%; }

    .menu-toggle{
      display:none;
      width:44px;
      height:44px;
      border:none;
      background:rgba(111,168,220,0.12);
      border:1px solid rgba(111,168,220,0.25);
      border-radius:12px;
      cursor:pointer;
      align-items:center;
      justify-content:center;
      flex-direction:column;
      gap:5px;
      padding:0;
    }
    .menu-toggle span{
      width:18px;
      height:2px;
      background:var(--header-ink);
      border-radius:2px;
      transition:transform .25s ease, opacity .25s ease;
    }
    .menu-toggle.is-active span:nth-child(1){ transform:translateY(7px) rotate(45deg); }
    .menu-toggle.is-active span:nth-child(2){ opacity:0; }
    .menu-toggle.is-active span:nth-child(3){ transform:translateY(-7px) rotate(-45deg); }

    .hero{
      min-height:92vh;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding:140px 32px 100px;
      background:linear-gradient(180deg,#8FC1E8 0%,#5B98D2 100%);
      overflow:hidden;
    }
    .hero-slides{
      position:absolute;
      inset:0;
      z-index:0;
      pointer-events:none;
    }
    .hero-slide{
      position:absolute;
      inset:0;
      opacity:0;
      transform:scale(1.06);
      transition:opacity 1.1s ease, transform 8s ease;
    }
    .hero-slide.is-active{
      opacity:1;
      transform:scale(1);
    }
    .hero-slide img{
      width:100%;
      height:100%;
      object-fit:cover;
    }
    .hero-slides::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at 18% 20%, rgba(15,42,74,0.26) 0%, transparent 42%),
        radial-gradient(circle at 84% 78%, rgba(15,42,74,0.20) 0%, transparent 45%),
        linear-gradient(180deg, rgba(9,28,50,0.58) 0%, rgba(11,32,56,0.38) 45%, rgba(15,42,74,0.58) 100%);
    }
    .hero-inner{
      position:relative;
      z-index:2;
      max-width:1100px;
      animation:fadeUp .9s ease both;
    }
    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:8px;
      font-size:12px;
      font-weight:700;
      letter-spacing:0.10em;
      text-transform:uppercase;
      color:#D6E6F7;
      margin-bottom:24px;
      animation:fadeUp .9s ease .1s both;
    }
    .eyebrow-dot{
      width:6px;
      height:6px;
      border-radius:50%;
      background:#A8E0D0;
      box-shadow:0 0 0 8px rgba(168,224,208,0.12);
    }
    h1{
      font-family:'Poppins',sans-serif;
      font-weight:700;
      font-size:clamp(22px, 3.2vw, 42px);
      line-height:1.15;
      letter-spacing:-0.02em;
      color:var(--white);
      text-shadow:0 4px 24px rgba(0,0,0,0.42);
    }
    h1 .line{
      white-space:nowrap;
    }
    .divider{
      width:64px;
      height:3px;
      background:linear-gradient(90deg,#A8E0D0,var(--navy-soft));
      margin:26px auto;
      border-radius:2px;
      animation:growLine 1s ease .3s both;
    }
    .hero-copy{
      font-size:17px;
      line-height:1.75;
      color:rgba(255,255,255,0.92);
      max-width:620px;
      margin:0 auto;
      text-shadow:0 2px 14px rgba(0,0,0,0.32);
      animation:fadeUp .9s ease .35s both;
    }
    .hero-actions{
      margin-top:38px;
      animation:fadeUp .9s ease .45s both;
    }
    .btn-primary{
      font-family:'Poppins',sans-serif;
      background:var(--white);
      color:var(--navy);
      font-weight:700;
      font-size:13.5px;
      letter-spacing:0.04em;
      text-transform:uppercase;
      padding:17px 34px;
      border-radius:999px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      transition:all .25s ease;
      box-shadow:0 16px 34px rgba(0,0,0,0.18);
      border:none;
      cursor:pointer;
    }
    .btn-primary:hover{
      background:var(--navy-soft);
      color:var(--white);
      transform:translateY(-3px) scale(1.02);
    }
    .hero-dots{
      position:absolute;
      left:50%;
      bottom:36px;
      transform:translateX(-50%);
      z-index:2;
      display:flex;
      gap:9px;
    }
    .hero-dots span{
      width:7px;
      height:7px;
      border-radius:50%;
      background:rgba(255,255,255,0.35);
      transition:all .3s ease;
      cursor:pointer;
    }
    .hero-dots span.is-active{
      background:var(--white);
      width:22px;
      border-radius:4px;
    }

    .section{
      padding:96px 48px;
    }
    .section.alt{
      background:var(--silver);
    }
    .section-inner{
      max-width:1240px;
      margin:0 auto;
    }
    .section-head{
      max-width:640px;
      margin-bottom:52px;
      opacity:0;
      transform:translateY(28px);
      transition:opacity .8s ease, transform .8s ease;
    }
    .section.is-visible .section-head{
      opacity:1;
      transform:translateY(0);
    }
    .kicker{
      font-family:'Poppins',sans-serif;
      font-size:12px;
      font-weight:700;
      letter-spacing:0.08em;
      text-transform:uppercase;
      color:var(--navy-soft);
      margin-bottom:12px;
      display:block;
    }
    .section-head h2,
    .about-text h2,
    .contact-box h2,
    .modal-header h3,
    .portfolio-modal-content h4{
      font-family:'Poppins',sans-serif;
      letter-spacing:-0.01em;
    }
    .section-head h2{
      font-weight:700;
      font-size:34px;
      color:var(--navy);
      line-height:1.2;
    }
    .section-head p{
      margin-top:14px;
      font-size:16px;
      line-height:1.75;
      color:var(--muted);
    }

    .about-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:56px;
      align-items:center;
    }
    .about-visual{
      display:flex;
      justify-content:center;
      opacity:0;
      transform:translateX(-30px) scale(.98);
      transition:opacity .8s ease, transform .8s ease;
    }
    .about-text{
      opacity:0;
      transform:translateX(30px);
      transition:opacity .8s ease, transform .8s ease;
    }
    .section.is-visible .about-visual,
    .section.is-visible .about-text{
      opacity:1;
      transform:translateX(0) scale(1);
    }
    .about-visual img{
      max-width:100%;
      filter:drop-shadow(0 22px 36px rgba(15,42,74,0.15));
      animation:floatY 5s ease-in-out infinite;
    }
    .about-text h2{
      font-weight:700;
      font-size:32px;
      color:var(--navy);
      line-height:1.22;
      margin-bottom:14px;
    }
    .about-text p{
      font-size:16px;
      line-height:1.8;
      color:var(--muted);
    }

    .value-grid{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:32px;
      text-align:center;
    }
    .value-card{
      opacity:0;
      transform:translateY(22px);
      transition:opacity .7s ease, transform .7s ease;
    }
    .section.is-visible .value-card{
      opacity:1;
      transform:translateY(0);
    }
    .value-card:nth-child(1){ transition-delay:.05s; }
    .value-card:nth-child(2){ transition-delay:.15s; }
    .value-card:nth-child(3){ transition-delay:.25s; }
    .value-card:nth-child(4){ transition-delay:.35s; }
    .value-icon{
      width:56px;
      height:56px;
      margin:0 auto 18px;
      border-radius:16px;
      display:flex;
      align-items:center;
      justify-content:center;
      color:var(--navy-soft);
      background:rgba(111,168,220,0.12);
      transition:transform .35s ease, background .35s ease;
    }
    .value-card:hover .value-icon{
      transform:translateY(-4px) rotate(-6deg) scale(1.06);
      background:rgba(111,168,220,0.20);
    }
    .value-icon svg{ width:26px; height:26px; }
    .value-card h3{
      font-family:'Poppins',sans-serif;
      font-size:19px;
      font-weight:600;
      color:var(--navy);
      margin-bottom:8px;
    }
    .value-card p{
      font-size:14px;
      line-height:1.7;
      color:var(--muted);
      max-width:220px;
      margin:0 auto;
    }

    .process-wrap{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:0;
      position:relative;
    }
    .process-line{
      position:absolute;
      top:27px;
      left:12.5%;
      right:12.5%;
      height:2px;
      background:repeating-linear-gradient(90deg, var(--line) 0 10px, transparent 10px 18px);
      z-index:0;
    }
    .process-step{
      position:relative;
      z-index:1;
      padding:0 18px;
      opacity:0;
      transform:translateY(22px);
      transition:opacity .7s ease, transform .7s ease;
    }
    .section.is-visible .process-step{
      opacity:1;
      transform:translateY(0);
    }
    .process-step:nth-child(2){ transition-delay:.08s; }
    .process-step:nth-child(3){ transition-delay:.18s; }
    .process-step:nth-child(4){ transition-delay:.28s; }
    .process-step:nth-child(5){ transition-delay:.38s; }
    .process-num{
      width:54px;
      height:54px;
      border-radius:50%;
      background:var(--navy);
      color:var(--white);
      display:flex;
      align-items:center;
      justify-content:center;
      font-family:'Poppins',sans-serif;
      font-size:20px;
      font-weight:700;
      margin-bottom:20px;
      box-shadow:0 10px 22px rgba(42,94,149,0.28);
      transition:transform .3s ease;
    }
    .process-step:hover .process-num{
      transform:scale(1.08);
    }
    .process-step h3{
      font-family:'Poppins',sans-serif;
      font-size:18px;
      font-weight:600;
      color:var(--navy);
      margin-bottom:8px;
    }
    .process-step p{
      font-size:13.5px;
      line-height:1.65;
      color:var(--muted);
    }

    .service-grid{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:20px;
    }
    .service-card:nth-child(1){ transition-delay:.05s; }
    .service-card:nth-child(2){ transition-delay:.15s; }
    .service-card:nth-child(3){ transition-delay:.25s; }
    .service-card:nth-child(4){ transition-delay:.35s; }
    .p-tile:nth-child(1){ transition-delay:.05s; }
    .p-tile:nth-child(2){ transition-delay:.12s; }
    .p-tile:nth-child(3){ transition-delay:.19s; }
    .p-tile:nth-child(4){ transition-delay:.26s; }
    .service-card{
      background:var(--white);
      border:1px solid var(--line);
      border-radius:18px;
      padding:28px 22px;
      transition:transform .25s ease, box-shadow .25s ease, border-color .25s ease, opacity .8s ease;
      opacity:0;
      transform:translateY(24px);
      perspective:1000px;
    }
    .section.is-visible .service-card{
      opacity:1;
      transform:translateY(0);
    }
    .service-card:hover{
      border-color:var(--navy-soft);
      transform:translateY(-8px) rotateX(4deg) rotateY(-4deg);
      box-shadow:0 22px 40px rgba(15,42,74,0.14);
    }
    .service-icon{
      width:44px;
      height:44px;
      border-radius:12px;
      background:rgba(111,168,220,0.12);
      color:var(--navy-soft);
      display:flex;
      align-items:center;
      justify-content:center;
      margin-bottom:18px;
      transition:transform .3s ease, background .3s ease;
    }
    .service-card:hover .service-icon{
      transform:rotate(10deg) scale(1.06);
      background:rgba(111,168,220,0.20);
    }
    .service-card h3{
      font-family:'Poppins',sans-serif;
      font-size:19px;
      font-weight:600;
      color:var(--navy);
      margin-bottom:8px;
    }
    .service-card p{
      font-size:13.5px;
      line-height:1.65;
      color:var(--muted);
    }

    .portfolio-slider{
      overflow:hidden;
      position:relative;
      cursor:pointer;
    }
    .portfolio-track{
      display:flex;
      width:max-content;
      animation:portfolioScroll 18s linear infinite;
      will-change:transform;
    }
    .portfolio-slider.is-paused .portfolio-track{
      animation-play-state:paused;
    }
    .portfolio-group{
      display:flex;
      gap:20px;
      padding-right:20px;
    }
    .p-tile{
      position:relative;
      border-radius:18px;
      overflow:hidden;
      aspect-ratio:3/3.6;
      box-shadow:0 14px 30px rgba(15,42,74,0.14);
      flex:0 0 280px;
      cursor:pointer;
      opacity:0;
      transform:translateY(22px) scale(.98);
      transition:transform .35s ease, box-shadow .35s ease, opacity .8s ease;
    }
    .section.is-visible .p-tile{
      opacity:1;
      transform:translateY(0) scale(1);
    }
    .p-tile:hover{
      transform:translateY(-8px) scale(1.01);
      box-shadow:0 22px 42px rgba(15,42,74,0.22);
    }
    .p-tile img{
      width:100%;
      height:100%;
      object-fit:cover;
      transition:transform .7s ease, filter .7s ease;
    }
    .p-tile:hover img{
      transform:scale(1.10);
      filter:saturate(1.1) contrast(1.03);
    }
    .p-tile::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(180deg, rgba(15,42,74,0) 45%, rgba(9,25,46,0.72) 100%);
    }
    .p-label{
      position:absolute;
      left:16px;
      bottom:16px;
      z-index:2;
      color:var(--white);
      transform:translateY(10px);
      transition:transform .3s ease;
    }
    .p-tile:hover .p-label{
      transform:translateY(0);
    }
    .p-label b{
      display:block;
      font-family:'Poppins',sans-serif;
      font-size:16px;
      font-weight:600;
    }
    .p-label span{
      font-size:12px;
      color:rgba(255,255,255,0.75);
    }

    .contact-box{
      background:linear-gradient(160deg,var(--navy) 0%,var(--navy-2) 100%);
      border-radius:28px;
      padding:68px 56px;
      text-align:center;
      position:relative;
      overflow:hidden;
      opacity:0;
      transform:translateY(24px);
      transition:opacity .8s ease, transform .8s ease;
    }
    .section.is-visible .contact-box{
      opacity:1;
      transform:translateY(0);
    }
    .contact-box::before{
      content:"";
      position:absolute;
      inset:0;
      background-image:radial-gradient(circle, rgba(255,255,255,0.08) 1.4px, transparent 1.4px);
      background-size:24px 24px;
      opacity:.5;
      animation:drift 18s linear infinite;
    }
    .contact-box h2{
      position:relative;
      font-size:32px;
      font-weight:700;
      color:var(--white);
    }
    .contact-box p{
      position:relative;
      margin:16px auto 32px;
      max-width:480px;
      color:rgba(255,255,255,0.74);
      font-size:15.5px;
      line-height:1.75;
    }
    .contact-links{
      position:relative;
      display:flex;
      justify-content:center;
      gap:16px;
      flex-wrap:wrap;
    }

    .modal{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      z-index:999;
      padding:24px;
      opacity:0;
    }
    .modal.is-open{
      display:flex;
      opacity:1;
    }
    .modal-overlay{
      position:absolute;
      inset:0;
      background:rgba(6,16,30,0.62);
      backdrop-filter:blur(6px);
    }
    .modal-card{
      position:relative;
      z-index:1;
      width:min(720px,100%);
      background:#fff;
      border-radius:24px;
      box-shadow:0 28px 70px rgba(0,0,0,0.28);
      padding:32px;
      transform:translateY(20px) scale(.98);
      animation:modalIn .28s ease forwards;
      max-height:90vh;
      overflow:auto;
    }
    .modal-close{
      position:absolute;
      top:16px;
      right:16px;
      width:42px;
      height:42px;
      border:none;
      background:#eef2f7;
      color:#0f2a4a;
      border-radius:50%;
      font-size:24px;
      cursor:pointer;
      line-height:1;
      transition:transform .2s ease, background .2s ease;
    }
    .modal-close:hover{
      transform:rotate(90deg);
      background:#dde5ef;
    }
    .modal-header h3{
      font-size:28px;
      color:#0F2A4A;
      margin-bottom:8px;
    }
    .modal-header p{
      color:#5B6472;
      margin-bottom:24px;
      line-height:1.7;
    }
    .contact-form{
      display:grid;
      gap:16px;
    }
    .form-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:16px;
    }
    .field{
      display:grid;
      gap:8px;
    }
    .field label{
      font-size:14px;
      font-weight:700;
      color:#0F2A4A;
    }
    .field input,
    .field textarea{
      width:100%;
      border:1px solid rgba(15,42,74,0.16);
      border-radius:14px;
      padding:14px 16px;
      font-size:14px;
      outline:none;
      background:#fff;
      transition:border-color .2s ease, box-shadow .2s ease, transform .2s ease;
    }
    .field input:focus,
    .field textarea:focus{
      border-color:var(--navy);
      box-shadow:0 0 0 4px rgba(58,116,173,0.12);
      transform:translateY(-1px);
    }
    .field textarea{
      resize:vertical;
      min-height:140px;
    }
    .modal-actions{
      margin-top:6px;
      display:flex;
      gap:12px;
      justify-content:flex-end;
    }
    .btn-secondary{
      font-family:'Poppins',sans-serif;
      background:#eef2f7;
      color:#0F2A4A;
      font-weight:700;
      font-size:13.5px;
      letter-spacing:0.04em;
      text-transform:uppercase;
      padding:16px 24px;
      border-radius:999px;
